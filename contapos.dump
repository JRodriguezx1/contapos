DROP TABLE IF EXISTS `productosseparados`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `productosseparados` (
  `id` int NOT NULL AUTO_INCREMENT,
  `idcredito` int NOT NULL,
  `idproducto` int DEFAULT NULL,
  `tipoproducto` tinyint(1) DEFAULT NULL,
  `tipoproduccion` tinyint(1) DEFAULT NULL,
  `promediostock` decimal(8,2) DEFAULT '0.00',
  `rendimientoestandar` decimal(11,2) DEFAULT NULL,
  `nombreproducto` varchar(124) COLLATE utf8mb4_unicode_ci NOT NULL,
  `foto` varchar(99) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `costo` decimal(12,2) DEFAULT '0.00',
  `valorunidad` decimal(12,2) DEFAULT '0.00',
  `cantidad` decimal(10,2) NOT NULL DEFAULT '1.00',
  `subtotal` decimal(13,2) DEFAULT '0.00',
  `base` decimal(12,3) DEFAULT '0.000',
  `impuesto` varchar(11) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `valorimp` decimal(12,3) DEFAULT '0.000',
  `descuento` decimal(12,2) DEFAULT '0.00',
  `total` decimal(13,2) DEFAULT '0.00',
  `created_at` timestamp NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`),
  KEY `productoid_idx` (`idproducto`),
  KEY `idcredito_idx` (`idcredito`),
  CONSTRAINT `fk_producto` FOREIGN KEY (`idproducto`) REFERENCES `productos` (`id`) ON DELETE SET NULL ON UPDATE CASCADE,
  CONSTRAINT `idcredito` FOREIGN KEY (`idcredito`) REFERENCES `creditos` (`id`) ON DELETE CASCADE ON UPDATE CASCADE
) ENGINE=InnoDB AUTO_INCREMENT=35 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
