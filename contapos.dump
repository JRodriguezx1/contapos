--
-- Table structure for table `movimientos_productos`
--

DROP TABLE IF EXISTS `movimientos_productos`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `movimientos_productos` (
  `id` int NOT NULL AUTO_INCREMENT,
  `idfksucursal` int NOT NULL,
  `idproducto_id` int NOT NULL,
  `id_usuarioid` int DEFAULT NULL,
  `nombreusuario` varchar(80) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `tipo` varchar(45) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci NOT NULL,
  `referencia` varchar(45) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `cantidad` decimal(12,2) NOT NULL,
  `stockanterior` decimal(12,2) NOT NULL,
  `stocknuevo` decimal(12,2) NOT NULL,
  `comentario` tinytext CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci,
  `created_at` timestamp NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`),
  KEY `idfksucursal_idx` (`idfksucursal`),
  KEY `idproducto_id_idx` (`idproducto_id`),
  KEY `id_usuarioid_idx` (`id_usuarioid`),
  CONSTRAINT `id_usuarioid` FOREIGN KEY (`id_usuarioid`) REFERENCES `usuarios` (`id`) ON DELETE SET NULL ON UPDATE CASCADE,
  CONSTRAINT `idfksucursal` FOREIGN KEY (`idfksucursal`) REFERENCES `sucursales` (`id`) ON DELETE CASCADE ON UPDATE CASCADE,
  CONSTRAINT `idproducto_id` FOREIGN KEY (`idproducto_id`) REFERENCES `productos` (`id`) ON DELETE CASCADE ON UPDATE CASCADE
) ENGINE=InnoDB AUTO_INCREMENT=1197 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
/*!40101 SET character_set_client = @saved_cs_client */;

