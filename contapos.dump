--
-- Table structure for table `compras`
--

DROP TABLE IF EXISTS `compras`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `compras` (
  `id` int NOT NULL AUTO_INCREMENT,
  `id_sucursal_id` int DEFAULT NULL,
  `idusuario` int DEFAULT NULL,
  `idproveedor` int DEFAULT NULL,
  `idformapago` int DEFAULT NULL,
  `idorigencaja` int DEFAULT NULL,
  `idorigenbanco` int DEFAULT NULL,
  `nombreorigencaja` varchar(45) CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci DEFAULT NULL,
  `nombreorigenbanco` varchar(45) CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci DEFAULT NULL,
  `nombreusuario` varchar(45) CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci NOT NULL,
  `nombreproveedor` varchar(45) CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci DEFAULT NULL,
  `formapago` varchar(45) CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci DEFAULT NULL,
  `nfactura` varchar(45) CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci DEFAULT NULL,
  `impuesto` decimal(6,2) DEFAULT '0.00',
  `valorimp` decimal(12,2) DEFAULT '0.00',
  `base` decimal(12,2) DEFAULT '0.00',
  `origenpago` tinyint(1) DEFAULT NULL,
  `nombreorigenpago` varchar(45) CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci DEFAULT NULL,
  `cantidaditems` int NOT NULL,
  `observacion` varchar(255) CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci DEFAULT NULL,
  `estado` varchar(22) CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci NOT NULL,
  `subtotal` decimal(12,2) NOT NULL,
  `valortotal` decimal(12,2) NOT NULL,
  `fechacompra` datetime NOT NULL,
  PRIMARY KEY (`id`),
  KEY `idusuario_idx` (`idusuario`),
  KEY `id_usuario_idx` (`idusuario`),
  KEY `id_sucursal_id_idx` (`id_sucursal_id`),
  KEY `idproveedor_idx` (`idproveedor`),
  CONSTRAINT `id_sucursal_id` FOREIGN KEY (`id_sucursal_id`) REFERENCES `sucursales` (`id`) ON UPDATE CASCADE,
  CONSTRAINT `idproveedor` FOREIGN KEY (`idproveedor`) REFERENCES `proveedores` (`id`) ON UPDATE CASCADE,
  CONSTRAINT `usuario_id` FOREIGN KEY (`idusuario`) REFERENCES `usuarios` (`id`) ON DELETE SET NULL ON UPDATE CASCADE
) ENGINE=InnoDB AUTO_INCREMENT=30 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
/*!40101 SET character_set_client = @saved_cs_client */;

