  `fromNC` int DEFAULT NULL,
  `toNC` int DEFAULT NULL,
  `date_from` date DEFAULT NULL,
  `date_to` date DEFAULT NULL,
  `estado` tinyint(1) NOT NULL,
  `created_at` timestamp NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`),
  KEY `idsucursal_idfk_idx` (`idsucursal_id_fk`),
  KEY `id_compania_idx` (`id_compania`),
  CONSTRAINT `id_compania` FOREIGN KEY (`id_compania`) REFERENCES `diancompanias` (`id`) ON DELETE SET NULL ON UPDATE CASCADE,
  CONSTRAINT `idsucursal_id_fk` FOREIGN KEY (`idsucursal_id_fk`) REFERENCES `sucursales` (`id`) ON DELETE CASCADE ON UPDATE CASCADE
