--
-- Table structure for table `creditos`
--

DROP TABLE IF EXISTS `creditos`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `creditos` (
  `id` int NOT NULL AUTO_INCREMENT,
  `id_fksucursal` int NOT NULL,
  `idemisor` int DEFAULT NULL,
  `usuariofk` int DEFAULT NULL,
  `idtipofinanciacion` int NOT NULL,
  `factura_id` int DEFAULT NULL,
  `cliente_id` int NOT NULL,
  `idestadocreditos` int NOT NULL,
  `num_orden` int DEFAULT NULL,
  `nombrecliente` varchar(70) CHARACTER SET utf8mb3 COLLATE utf8mb3_spanish_ci NOT NULL,
  `capital` decimal(12,2) NOT NULL,
  `abonoinicial` decimal(10,2) DEFAULT '0.00',
  `abonodecuotas` decimal(12,2) DEFAULT '0.00',
  `saldopendiente` decimal(12,2) NOT NULL DEFAULT '0.00',
  `numcuota` int DEFAULT '0',
  `cantidadcuotas` int NOT NULL DEFAULT '0',
  `montocuota` decimal(12,2) NOT NULL DEFAULT '0.00',
  `frecuenciapago` varchar(45) CHARACTER SET utf8mb3 COLLATE utf8mb3_spanish_ci DEFAULT NULL,
  `fechainicio` date DEFAULT NULL,
  `fechafin` datetime DEFAULT NULL,
  `interes` tinyint(1) NOT NULL,
  `interesxcuota` decimal(6,2) DEFAULT '0.00',
  `interestotal` decimal(6,2) DEFAULT '0.00',
  `valorinteresxcuota` decimal(12,2) DEFAULT '0.00',
  `valorinterestotal` decimal(12,2) DEFAULT '0.00',
  `montototal` decimal(12,2) NOT NULL,
  `fechavencimiento` date DEFAULT NULL,
  `productoentregado` tinyint(1) DEFAULT '0',
  `totalunidades` decimal(11,2) DEFAULT NULL,
  `base` decimal(13,3) DEFAULT NULL,
  `valorimpuestototal` decimal(12,3) DEFAULT '0.000',
  `dctox100` int DEFAULT '0',
  `descuento` decimal(12,2) DEFAULT '0.00',
  `abonototalantiguo` decimal(12,2) DEFAULT '0.00',
  `cantidadcuotasantiguas` int DEFAULT '0',
  `fechaultimoabonoantiguo` datetime DEFAULT NULL,
  `nota` varchar(121) CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci DEFAULT NULL,
  `estado` tinyint(1) DEFAULT '1',
  `created_at` timestamp NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`),
  KEY `idsucursalfk_idx` (`id_fksucursal`),
  KEY `cliente_id_idx` (`cliente_id`),
  KEY `factura_id_idx` (`factura_id`),
  KEY `idtipofinanciacion_idx` (`idtipofinanciacion`),
  KEY `usuariofk_idx` (`usuariofk`),
  KEY `idestadocreditos_idx` (`idestadocreditos`),
  KEY `idemisor_crd_idx` (`idemisor`),
  CONSTRAINT `cliente_id` FOREIGN KEY (`cliente_id`) REFERENCES `clientes` (`id`) ON DELETE CASCADE ON UPDATE CASCADE,
  CONSTRAINT `factura_id` FOREIGN KEY (`factura_id`) REFERENCES `facturas` (`id`) ON DELETE CASCADE ON UPDATE CASCADE,
  CONSTRAINT `id_fksucursal` FOREIGN KEY (`id_fksucursal`) REFERENCES `sucursales` (`id`) ON DELETE CASCADE ON UPDATE CASCADE,
  CONSTRAINT `idemisor_crd` FOREIGN KEY (`idemisor`) REFERENCES `emisores` (`id`) ON DELETE CASCADE ON UPDATE CASCADE,
  CONSTRAINT `idestadocreditos` FOREIGN KEY (`idestadocreditos`) REFERENCES `estadocreditos` (`id`) ON UPDATE CASCADE,
  CONSTRAINT `idtipofinanciacion` FOREIGN KEY (`idtipofinanciacion`) REFERENCES `tipofinanciacion` (`id`) ON UPDATE CASCADE,
  CONSTRAINT `usuariofk` FOREIGN KEY (`usuariofk`) REFERENCES `usuarios` (`id`) ON DELETE SET NULL ON UPDATE CASCADE
) ENGINE=InnoDB AUTO_INCREMENT=71 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
/*!40101 SET character_set_client = @saved_cs_client */;

