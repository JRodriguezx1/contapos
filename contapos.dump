--
-- Table structure for table `facturas`
--

DROP TABLE IF EXISTS `facturas`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `facturas` (
  `id` int NOT NULL AUTO_INCREMENT,
  `idemisor` int DEFAULT NULL,
  `id_sucursal` int DEFAULT NULL,
  `idcliente` int DEFAULT NULL,
  `idvendedor` int DEFAULT NULL,
  `idrepartidorcobrador` int DEFAULT NULL,
  `idcaja` int DEFAULT NULL,
  `idconsecutivo` int DEFAULT NULL,
  `iddireccion` int DEFAULT NULL,
  `idtarifazona` int DEFAULT NULL,
  `idcierrecaja` int DEFAULT NULL,
  `idcanaldeventa` int DEFAULT '1',
  `num_orden` int DEFAULT NULL,
  `prefijo` varchar(45) CHARACTER SET utf8mb3 COLLATE utf8mb3_spanish_ci DEFAULT NULL,
  `num_consecutivo` int DEFAULT NULL,
  `cliente` varchar(75) CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci DEFAULT NULL,
  `vendedor` varchar(55) CHARACTER SET utf8mb3 COLLATE utf8mb3_unicode_ci DEFAULT NULL,
  `caja` varchar(33) CHARACTER SET utf8mb3 COLLATE utf8mb3_spanish_ci DEFAULT NULL,
  `tipofacturador` varchar(33) CHARACTER SET utf8mb3 COLLATE utf8mb3_unicode_ci DEFAULT NULL,
  `propina` decimal(11,2) DEFAULT NULL,
  `direccion` varchar(77) CHARACTER SET utf8mb3 COLLATE utf8mb3_unicode_ci DEFAULT NULL,
  `tarifazona` varchar(55) CHARACTER SET utf8mb3 COLLATE utf8mb3_unicode_ci DEFAULT NULL,
  `totalunidades` decimal(11,2) DEFAULT NULL,
  `recibido` decimal(12,2) DEFAULT NULL,
  `cambio` decimal(12,2) DEFAULT NULL,
