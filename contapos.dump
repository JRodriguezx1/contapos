--
-- Table structure for table `facturas_electronicas`
--

DROP TABLE IF EXISTS `facturas_electronicas`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `facturas_electronicas` (
  `id` int NOT NULL AUTO_INCREMENT,
  `id_sucursalidfk` int NOT NULL,
  `id_estadoelectronica` int NOT NULL,
  `consecutivo_id` int NOT NULL,
  `id_facturaid` int NOT NULL,
  `id_adquiriente` int DEFAULT NULL,
  `id_estadonota` int DEFAULT NULL,
  `numero` int NOT NULL,
  `num_factura` varchar(20) CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci NOT NULL,
  `prefijo` varchar(11) CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci NOT NULL,
  `resolucion` varchar(20) CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci DEFAULT NULL,
  `token_electronica` varchar(100) CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci NOT NULL,
  `cufe` varchar(256) CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci DEFAULT NULL,
  `qr` varchar(256) CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci DEFAULT NULL,
  `filename` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci DEFAULT NULL,
  `nitcompany` varchar(25) CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci DEFAULT NULL,
  `fecha_factura` timestamp NULL DEFAULT NULL,
  `identificacion` varchar(20) CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci NOT NULL,
  `nombre` varchar(200) CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci NOT NULL,
  `email` varchar(100) CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci DEFAULT NULL,
  `link` varchar(256) CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci DEFAULT NULL,
  `nota_credito` tinyint(1) NOT NULL DEFAULT '0',
  `prefixnc` varchar(11) CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci DEFAULT NULL,
  `num_nota` int DEFAULT NULL,
  `cufe_nota` varchar(256) CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci DEFAULT NULL,
  `qrnc` varchar(256) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `linknc` varchar(256) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `filenamenc` varchar(32) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `fecha_nota` datetime DEFAULT NULL,
  `is_auto` int DEFAULT NULL,
  `json_envio` text CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci,
  `json_envionc` text COLLATE utf8mb4_unicode_ci,
  `respuesta_factura` text CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci,
  `respuesta_nota` text CHARACTER SET utf8mb4 COLLATE utf8mb4_spanish_ci,
  `intentos_de_envio` int DEFAULT NULL,
  `fecha_ultimo_intento` datetime DEFAULT NULL,
  `created_at` timestamp NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`),
  KEY `fk_adquiriente` (`id_adquiriente`),
  KEY `fk_atencion` (`id_facturaid`) /*!80000 INVISIBLE */,
