  CONSTRAINT `cajaid` FOREIGN KEY (`cajaid`) REFERENCES `caja` (`id`) ON UPDATE CASCADE,
  CONSTRAINT `cierrecaja_id` FOREIGN KEY (`cierrecaja_id`) REFERENCES `cierrescajas` (`id`) ON DELETE CASCADE ON UPDATE CASCADE,
  CONSTRAINT `id_credito` FOREIGN KEY (`id_credito`) REFERENCES `creditos` (`id`) ON DELETE CASCADE ON UPDATE CASCADE,
  CONSTRAINT `id_sucursal_idfk` FOREIGN KEY (`id_sucursal_idfk`) REFERENCES `sucursales` (`id`) ON DELETE CASCADE ON UPDATE CASCADE,
  CONSTRAINT `idusuario_cu` FOREIGN KEY (`idusuario`) REFERENCES `usuarios` (`id`) ON DELETE SET NULL ON UPDATE CASCADE,
  CONSTRAINT `mediopagoid` FOREIGN KEY (`mediopagoid`) REFERENCES `mediospago` (`id`) ON UPDATE CASCADE
) ENGINE=InnoDB AUTO_INCREMENT=236 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
