  `detalle` varchar(255) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `estado` tinyint(1) NOT NULL,
  `created_at` timestamp NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`),
  KEY `id_credito_idx` (`id_credito`),
  KEY `id_mediopago_idx` (`mediopagoid`),
  KEY `id_sucursalidfk_idx` (`id_sucursal_idfk`),
  KEY `cajaid_idx` (`cajaid`),
