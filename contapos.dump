DROP TABLE IF EXISTS `creditos_compras`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `creditos_compras` (
  `id` int NOT NULL AUTO_INCREMENT,
  `id_sucursal_fk` int NOT NULL,
  `compra_id` int NOT NULL,
  `id_proveedor` int DEFAULT NULL,
  `nombreproveedor` varchar(45) CHARACTER SET utf8mb3 COLLATE utf8mb3_spanish_ci NOT NULL,
  `montototal` decimal(12,2) NOT NULL,
  `saldopendiente` decimal(12,2) NOT NULL DEFAULT '0.00',
  `cantidadcuotas` int NOT NULL DEFAULT '0',
  `montocuota` decimal(12,2) NOT NULL DEFAULT '0.00',
  `frecuenciapago` varchar(45) CHARACTER SET utf8mb3 COLLATE utf8mb3_spanish_ci DEFAULT NULL,
  `fechainicio` date DEFAULT NULL,
  `tasainteres` decimal(6,2) DEFAULT '0.00',
  `estado` tinyint(1) DEFAULT '1',
  `created_at` timestamp NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`id`),
  KEY `id_sucursal_fk_idx` (`id_sucursal_fk`),
  KEY `compra_id_idx` (`compra_id`),
  KEY `id_proveedor_idx` (`id_proveedor`),
  CONSTRAINT `compra_id` FOREIGN KEY (`compra_id`) REFERENCES `compras` (`id`) ON DELETE CASCADE ON UPDATE CASCADE,
  CONSTRAINT `id_proveedor` FOREIGN KEY (`id_proveedor`) REFERENCES `proveedores` (`id`) ON DELETE SET NULL ON UPDATE CASCADE,
  CONSTRAINT `id_sucursal_fk` FOREIGN KEY (`id_sucursal_fk`) REFERENCES `sucursales` (`id`) ON DELETE CASCADE ON UPDATE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb3 COLLATE=utf8mb3_unicode_ci;
